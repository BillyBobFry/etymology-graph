# Used by local scripts and non-Compose app services.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/etymology_graph
WIKTEXTRACT_PATH=wikidata_downloads/raw-wiktextract-data.jsonl
PORT=3000
HOST=127.0.0.1

# Used by docker-compose.yml and docker-compose.prod.yml for local/VPS Postgres.
# Set a real POSTGRES_PASSWORD in production; the app receives it as PGPASSWORD
# so special characters do not need URL encoding.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=etymology_graph

# Set HOST=0.0.0.0 in containers or managed app services.
# Set CORS_ORIGIN only when the frontend and API are served from different origins.
CORS_ORIGIN=

# Optional override for serving a built SPA from the API process.
STATIC_ASSETS_DIR=

# Leave blank for same-origin /api requests. Set to the API origin for split hosting.
VITE_API_BASE_URL=

# Full structured imports prune graph nodes with no edges and their embedding rows.
# Limited smoke imports skip pruning unless this is set to true.
IMPORT_PRUNE_ISOLATED_GRAPH=
