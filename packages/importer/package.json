{
  "name": "@etymology-graph/importer",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "import:sample": "tsx src/sample.ts",
    "seed:extract:popular": "tsx src/extract-popular-seed.ts",
    "seed:expand:prod": "tsx src/expand-popular-seed.ts",
    "seed:languages": "pnpm seed:languages:generate",
    "seed:languages:generate": "tsx src/generate-language-seed.ts",
    "seed:languages:validate": "tsx src/validate-language-seed.ts",
    "seed:languages:import": "tsx src/import-languages.ts",
    "import:batch-preview": "tsx src/batch-preview.ts",
    "import:db": "tsx src/import-db.ts"
  },
  "dependencies": {
    "@etymology-graph/graph": "workspace:*",
    "dotenv": "^17.4.2",
    "pg": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "vitest": "^4.1.7"
  }
}
