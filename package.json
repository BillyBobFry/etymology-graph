{
  "name": "etymology-graph",
  "private": true,
  "type": "module",
  "scripts": {
    "db:start": "docker compose up -d postgres",
    "dev": "pnpm --filter @etymology-graph/graph build && pnpm --parallel --filter @etymology-graph/api --filter @etymology-graph/web dev",
    "build": "pnpm -r build",
    "lint": "eslint .",
    "prepare": "node scripts/prepare-husky.mjs",
    "db:refresh:prod": "bash scripts/refresh-prod-db.sh",
    "typecheck": "pnpm --filter @etymology-graph/graph build && pnpm -r typecheck",
    "test:importer": "pnpm --filter @etymology-graph/graph build && pnpm --filter @etymology-graph/importer test",
    "import:sample": "pnpm --filter @etymology-graph/graph build && pnpm --filter @etymology-graph/importer import:sample",
    "seed:extract:structured-ancestry": "pnpm --filter @etymology-graph/graph build && WIKTEXTRACT_PATH=../../wikidata_downloads/raw-wiktextract-data.jsonl SEED_OUTPUT_PATH=../../wikidata_downloads/seeds/structured-ancestry-seed.jsonl STRUCTURED_ANCESTRY_FRONTIER_PATH=../../wikidata_downloads/checkpoints/structured-ancestry-frontier.json pnpm --filter @etymology-graph/importer seed:extract:structured-ancestry",
    "seed:languages": "pnpm --filter @etymology-graph/importer seed:languages:generate",
    "seed:languages:generate": "pnpm --filter @etymology-graph/importer seed:languages:generate",
    "seed:languages:validate": "pnpm --filter @etymology-graph/importer seed:languages:validate",
    "seed:languages:import": "pnpm --filter @etymology-graph/importer seed:languages:import",
    "atlas:refresh:source-languages": "pnpm --filter @etymology-graph/graph build && pnpm --filter @etymology-graph/importer atlas:refresh:source-languages",
    "embeddings:refresh:english": "pnpm --filter @etymology-graph/importer embeddings:refresh:english",
    "import:batch-preview:structured": "pnpm --filter @etymology-graph/graph build && pnpm --filter @etymology-graph/importer import:batch-preview:structured",
    "import:db:structured": "pnpm --filter @etymology-graph/graph build && pnpm --filter @etymology-graph/importer import:db:structured",
    "graph:reset:structured": "pnpm --filter @etymology-graph/importer graph:reset:structured",
    "llm:etymology": "pnpm --filter @etymology-graph/importer llm:etymology"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.1",
    "eslint": "^10.4.1",
    "eslint-plugin-vue": "^10.9.1",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0"
  }
}
